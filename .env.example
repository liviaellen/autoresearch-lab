# ============================================================
# autoresearch-lab — Environment Configuration
# ============================================================
# Copy this file to .env and fill in the values you need.
#   cp .env.example .env
#
# Only set the keys for providers you plan to use.
# Local models (Ollama) require no API keys.
# ============================================================

# --- Default Model ---
# Which model to use when --model is not specified.
# Presets: local, gpt4o, claude-sonnet, groq-llama, together-llama
# Or any LiteLLM model string: ollama/llama3.2, gpt-4o, etc.
AUTORESEARCH_MODEL=ollama/llama3.2

# --- OpenAI ---
# https://platform.openai.com/api-keys
OPENAI_API_KEY=

# --- Anthropic (Claude) ---
# https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=

# --- Groq ---
# https://console.groq.com/keys
GROQ_API_KEY=

# --- Together AI ---
# https://api.together.xyz/settings/api-keys
TOGETHER_API_KEY=

# --- OpenRouter ---
# https://openrouter.ai/keys
OPENROUTER_API_KEY=

# --- Custom OpenAI-compatible API ---
# For self-hosted models (vLLM, text-generation-inference, LocalAI, etc.)
# AUTORESEARCH_BASE_URL=http://localhost:8000/v1
# AUTORESEARCH_API_KEY=your-api-key-if-needed

# --- Ollama ---
# No API key needed. Just make sure Ollama is running:
#   ollama serve
#   ollama pull llama3.2
# Default host: http://localhost:11434
# OLLAMA_HOST=http://localhost:11434

# --- HuggingFace ---
# Only needed if downloading gated models or private datasets.
# HF_TOKEN=
